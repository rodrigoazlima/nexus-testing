{
  "name": "nexus-image-pipeline-tests",
  "version": "0.1.0",
  "private": true,
  "description": "Black-box Playwright tests for the Nexus Campaigns image ingestion pipeline (vault filesystem + dashboard UI).",
  "scripts": {
    "test": "playwright test --grep-invert @slow-agent",
    "test:pipeline:fast": "playwright test tests/pipeline --grep-invert @slow-agent",
    "test:pipeline:slow": "playwright test tests/pipeline --grep @slow-agent --workers=4",
    "test:unit": "node --import tsx --test tests/helpers/*.test.ts",
    "report": "playwright show-report",
    "clean": "tsx scripts/clean.ts",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
