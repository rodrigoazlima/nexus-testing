# Vault root — defaults to the current Nexus Campaigns vault if unset.
VAULT_PATH=C:\Users\rodrigo\OneDrive\pathway\vault

# Dashboard (vault-dashboard service) base URL.
DASHBOARD_URL=http://localhost:48080

# How long to wait for the vision daemon to produce a draft note (ms).
# Real interval is 900s (vision agent) on top of a 60s runtime loop, but a
# live run (2026-07-07) showed a large RAW/ backlog delaying a freshly
# dropped file by 3+ cycles (~50min) — budget generously.
POLL_TIMEOUT_MS=5100000

# How often to re-check the filesystem while waiting (ms). Kept coarse
# since the vault lives on OneDrive — avoid hammering a cloud-backed folder.
POLL_INTERVAL_MS=15000
