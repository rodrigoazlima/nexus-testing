# Root of the Obsidian vault under test.
VAULT_PATH=./.testing/vault

# Nexus daemon codebase/service install. Cloned fresh per run by
# tests/global-setup.ts and torn down by tests/global-teardown.ts.
# Must be on an NTFS volume (setup-service.ps1 links agents via junctions).
NEXUS_PATH=./.testing/nexus

# git branch/ref of NexusCampaigns to clone into NEXUS_PATH. Defaults to
# "master" if unset. Set this to test against a feature/in-progress branch
# instead -- it's passed straight to `git clone --branch <NEXUS_BRANCH>`, so
# an invalid branch/ref fails the clone immediately with git's own error.
NEXUS_BRANCH=master

# Dashboard base URL (Playwright baseURL).
DASHBOARD_URL=http://localhost:48080

# How long to poll the vault/state files for the daemon's output, in ms.
POLL_TIMEOUT_MS=600000

# Poll interval while waiting, in ms.
POLL_INTERVAL_MS=5000

# Playwright per-test timeout, in ms.
TEST_TIMEOUT_MS=600000
