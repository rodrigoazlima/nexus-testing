# Root of the Obsidian vault under test.
VAULT_PATH=./.testing/vault

# Nexus daemon codebase/service install. Cloned fresh per run by
# tests/global-setup.ts and torn down by tests/global-teardown.ts.
# Must be on an NTFS volume (setup-service.ps1 links agents via junctions).
NEXUS_PATH=./.testing/nexus

# git branch/ref of NexusCampaigns to clone into NEXUS_PATH. Defaults to
# "master" if unset. Set this to test against a feature/in-progress branch
# instead -- it's passed straight to `git clone --branch <NEXUS_BRANCH>`, so
# an invalid branch/ref fails the clone immediately with git's own error.
NEXUS_BRANCH=master

# git URL cloned into NEXUS_PATH. Defaults to the upstream NexusCampaigns
# repo if unset. Override to point at a fork (e.g. testing a personal fork
# before it's merged upstream).
NEXUS_REPO_URL=https://github.com/rodrigoazlima/NexusCampaigns.git

# Dashboard base URL (Playwright baseURL).
DASHBOARD_URL=http://localhost:48080

# Playwright runs headed (visible browser) by default. Set to 1 to run
# headless instead (e.g. CI).
HEADLESS=0

# Browser engine for all three projects. Pre-installed options: chromium
# (default), firefox.
# BROWSER=chromium

# How long to poll the vault/state files for the daemon's output, in ms.
POLL_TIMEOUT_MS=600000

# Poll interval while waiting, in ms.
POLL_INTERVAL_MS=5000

# Playwright per-test timeout, in ms.
TEST_TIMEOUT_MS=600000

# --- Advanced overrides ---
# Everything below is derived automatically from the vars above (or from
# repo-relative defaults) and normally never needs to be set. Uncomment only
# to point a specific path/value somewhere non-standard; leave unset to get
# the derived default shown in each comment.

# Repo root, anchors every relative default above. Defaults to the directory
# two levels up from tests/helpers/config.ts.
# ROOT_DIR=C:\opt\GitHub\nexus-testing

# Vault subfolder layout (fixed by the Nexus daemon's own convention).
# Defaults to <VAULT_PATH>/00-Inbox/images
# INBOX_IMAGES_DIR=
# Defaults to <VAULT_PATH>/00-Inbox/docs
# INBOX_DOCS_DIR=
# Defaults to <VAULT_PATH>/01-Processing
# PROCESSING_DIR=
# Defaults to <VAULT_PATH>/02-Library
# LIBRARY_DIR=
# Defaults to <VAULT_PATH>/99-Archive
# ARCHIVE_DIR=

# Nexus install layout. Defaults to <NEXUS_PATH>/system/ops/setup-service.ps1
# SETUP_SCRIPT=
# Defaults to <NEXUS_PATH>/agents/registry.yaml
# REGISTRY_PATH=

# Daemon state file locations (tests/helpers/nexus-state.ts), all under
# NEXUS_PATH by default — see that file for the exact default subpaths.
# INBOX_QUEUE_PATH=
# PROCESSED_IMAGES_PATH=
# PROCESSED_NPCS_PATH=
# SCENARIOS_PATH=
# WIKILINK_STATE_PATH=
# REPORTS_DIR=
# THUMBS_DIR=
# DAEMON_LOGS_DIR=
# TOKEN_CONFIG_PATH=
# GENERATED_TOKENS_PATH=

# Test-lane agent interval overrides, in seconds (tests/helpers/nexus-install.ts).
# Rewritten into the cloned registry.yaml so the fast lane doesn't wait out
# the daemon's stock 900s-86400s cadences.
# AGENT_INTERVAL_DEFAULT_S=300
# AGENT_INTERVAL_REPAIR_S=1500
# AGENT_INTERVAL_CLEANUP_S=1560

# Vision agent's tags[0] vocabulary and the dashboard's Bestiary entity
# types (tests/helpers/vault-utils.ts), comma-separated.
# IMAGE_CATEGORY_VOCAB=portrait,body,battlemap,scene,token
# BESTIARY_TYPES=creature,monster,encounter

# Resource-profiling output (tests/helpers/profile.ts).
# Defaults to <ROOT_DIR>/tmp/profile
# PROFILE_DIR=
# Defaults to <PROFILE_DIR>/resource-report.html
# REPORT_PATH=
